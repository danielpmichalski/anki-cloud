# Required: Anki sync credentials (username:password)
SYNC_USER1=username:password

# Storage backend: "gdrive" or "local" (default: local)
SYNC_STORAGE_PROVIDER=gdrive

# GDrive OAuth token (required when SYNC_STORAGE_PROVIDER=gdrive)
SYNC_OAUTH_TOKEN=your_oauth_access_token_here

# ── DATABASE ─────────────────────────────────────────────────────────────

# SQLite file URI — /data should be a Docker volume mount
DATABASE_URL=file:/data/anki-cloud.db

# 32-byte AES-256 key for encrypting OAuth tokens at rest
# Generate: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# ── REST API ─────────────────────────────────────────────────────────────

# Google OAuth2 app credentials (console.cloud.google.com → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must exactly match an authorized redirect URI in your Google OAuth app
GOOGLE_REDIRECT_URI=http://localhost:3000/v1/auth/google/callback

# JWT signing secret — 32-byte hex
# Generate: openssl rand -hex 32
JWT_SECRET=
