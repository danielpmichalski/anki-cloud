# ── ANKI SYNC SERVER ─────────────────────────────────────────────────────

# Required: Anki sync credentials (username:password)
SYNC_USER1=username:password

# Storage backend: "gdrive" or "local" (default: local)
SYNC_STORAGE_PROVIDER=gdrive

# GDrive OAuth token (required when SYNC_STORAGE_PROVIDER=gdrive)
SYNC_OAUTH_TOKEN=your_oauth_access_token_here

# ── SIDECAR (internal REST ↔ sync-server bridge) ─────────────────────────

# URL of the sync server's internal sidecar listener (not exposed publicly)
SIDECAR_URL=http://localhost:8081
# Shared secret for X-Internal-Token header — generate: openssl rand -hex 32
SIDECAR_TOKEN=

# ── DATABASE ─────────────────────────────────────────────────────────────

# SQLite file URI — /data should be a Docker volume mount
DATABASE_URL=file:/data/anki-cloud.db

# 32-byte AES-256 key for encrypting OAuth tokens at rest
# Generate: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# ── REST API ─────────────────────────────────────────────────────────────

# Google OAuth2 app credentials (console.cloud.google.com → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must exactly match an authorized redirect URI in your Google OAuth app
# When running web UI via Vite dev server (port 5173), use the 5173 URLs below so
# OAuth cookies land on the same origin as the UI. Add both to Google Cloud Console.
GOOGLE_REDIRECT_URI=http://localhost:5173/v1/auth/google/callback
# Must exactly match an authorized redirect URI in your Google OAuth app
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:5173/v1/me/storage/connect/gdrive/callback

# Frontend URL — API callbacks redirect here after OAuth flows complete
# Dev (Vite): http://localhost:5173   Prod: https://your-domain.com  Same-origin: /
FRONTEND_URL=http://localhost:5173

# JWT signing secret — 32-byte hex
# Generate: openssl rand -hex 32
JWT_SECRET=
