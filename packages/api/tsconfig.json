{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "lib": ["ES2022"],
    "types": ["bun"],
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./src/*"],
      "@anki-cloud/db": ["../db/src/index.ts"],
      "@anki-cloud/db/*": ["../db/src/*.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
